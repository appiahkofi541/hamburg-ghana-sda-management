# Supabase project settings:
# Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Backward-compatible alternative used by older Supabase projects:
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only WhatsApp Business Cloud API settings:
# Meta for Developers -> WhatsApp -> API Setup
WHATSAPP_ACCESS_TOKEN=your-server-only-access-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_GRAPH_API_VERSION=v25.0

# Server-only Stripe settings:
# Stripe Dashboard -> Developers -> API keys and Webhooks
STRIPE_SECRET_KEY=your-server-only-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-signing-secret
SUPABASE_SERVICE_ROLE_KEY=your-server-only-supabase-service-role-key
